# 复制为 .env.local

# --- Auth（Lab 06 必填）---
AUTH_SECRET=请生成至少32字符的随机字符串
ENCRYPTION_KEY=请生成至少32字符的随机字符串用于加密APIKey

# 生成示例（终端执行）：
# openssl rand -base64 32

# --- 方式 A：UI 设置页 BYOK（推荐）---
# 登录后在「Provider 设置」添加各平台 Key

# --- 方式 B：开发 fallback（无 BYOK 时使用）---
ZHIPU_API_KEY=粘贴真实智谱Key
# DASHSCOPE_API_KEY=sk-xxx
# GROQ_API_KEY=gsk_xxx
# OLLAMA_API_KEY=ollama

# --- 方式 C：纯环境变量切换 ---
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_API_KEY=粘贴真实Key
# LLM_MODEL=glm-4-flash

# MCP 由 UI「MCP 连接器」页面配置，无需环境变量

# SQLite
DATABASE_URL=file:./data/lab.db
