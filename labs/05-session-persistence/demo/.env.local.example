# 复制为 .env.local

# --- 方式 A：UI 下拉切换（推荐）---
# 按 Provider 分别配置 API Key，前端下拉选择，Key 仅存服务端
ZHIPU_API_KEY=粘贴真实智谱Key
# DASHSCOPE_API_KEY=sk-xxx   # 通义千问 https://bailian.console.aliyun.com
# GROQ_API_KEY=gsk_xxx
# OLLAMA_API_KEY=ollama

# --- 方式 B：纯环境变量切换 ---
# 注释掉上方 Key，改用下面三行，改 env 即可换 Provider
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_API_KEY=粘贴真实Key
# LLM_MODEL=glm-4-flash

# Ollama 示例：
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5:7b

# Groq 示例：
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_xxx
# LLM_MODEL=llama-3.1-8b-instant

# 通义千问示例：
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=sk-xxx
# LLM_MODEL=qwen-plus

# MCP 由 UI「MCP 连接器」页面配置，无需环境变量

# SQLite（Lab 05）
DATABASE_URL=file:./data/lab.db
